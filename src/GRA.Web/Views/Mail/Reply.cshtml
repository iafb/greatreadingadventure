@model GRA.Controllers.ViewModel.Mail.MailCreateViewModel

<form asp-controller="Mail" asp-action="Reply" method="post" role="form">
    <input asp-for="InReplyToId" type="hidden" />
    <input asp-for="InReplyToSubject" type="hidden" />
    <div class="row">
        <div class="col-12 col-lg-10 offset-lg-1">
            <div class="card">
                <h1 class="card-header h4">
					@SharedLocalizer[GRA.Annotations.Interface.ReplyTo]
                    @Model.InReplyToSubject
                </h1>
                <div class="card-body">
                    <div>
                        <label asp-for="Subject" class="col-form-label"></label>
                        <input asp-for="Subject" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Body" class="col-form-label"></label>
                        <textarea asp-for="Body" class="form-control" autocomplete="off"></textarea>
                        <span asp-validation-for="Body" class="text-danger"></span>
                    </div>

                </div>
                <div class="card-footer d-flex bg-white">
                    <div class="flex-grow-1">
                        <a asp-action="Read"
                           asp-route-id="@Model.InReplyToId"
                           class="btn btn-outline-secondary">
                            @SharedLocalizer[GRA.Annotations.Interface.Back]
                        </a>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            @SharedLocalizer[GRA.Annotations.Interface.BackToMailbox]
                        </a>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-outline-primary">
                            @SharedLocalizer[GRA.Annotations.Interface.SendReply]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
