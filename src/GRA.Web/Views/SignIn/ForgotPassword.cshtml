<form asp-controller="@SignInController.Name"
	  asp-action="@nameof(SignInController.ForgotPassword)"
	  method="post"
	  role="form">
	<div class="row">
		<div class="col-sm-12 col-md-8 offset-md-2">
			<div class="card">
				<h1 class="card-header h4">
					<grasite property="name"></grasite> -
					@SharedLocalizer[GRA.Domain.Model.DisplayNames.ForgotPassword]
				</h1>
				<div class="card-body">
					<div asp-validation-summary="All"></div>
					<div class="row mb-2">
						<div class="col">
							<label for="username" class="form-label">
								@SharedLocalizer[GRA.Domain.Model.DisplayNames.Username]
							</label>
							<input id="username"
								   name="username"
								   class="form-control form-control-lg"
								   autofocus
								   autocomplete="username" />
						</div>
					</div>
				</div>
				<div class="card-footer d-flex justify-content-end bg-white">
					<div>
						<a asp-action="@nameof(SignInController.Index)"
						   class="btn btn-outline-secondary btn-lg me-2">
							@SharedLocalizer[GRA.Domain.Model.DisplayNames.ReturnToSignIn]
						</a>
					</div>
					<div>
						<button class="btn btn-outline-primary btn-lg" button-spinner>
							@SharedLocalizer[GRA.Domain.Model.DisplayNames.SendRecoveryEmail]
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</form>